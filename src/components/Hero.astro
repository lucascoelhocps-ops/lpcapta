---
// Hero.astro
---

<section
  class="relative w-full min-h-screen flex items-center bg-brand-light overflow-hidden py-12 md:py-20"
>
  <!-- Subtle light gradient & overlay to create depth -->
  <div
    class="absolute inset-0 bg-gradient-to-tr from-[#ffffff] via-[#f8f9fa] to-[#f1f3f5] opacity-90 z-0"
  >
  </div>
  <div
    class="absolute w-[500px] h-[500px] bg-brand-yellow/10 rounded-full blur-[100px] top-0 left-[-20%] z-0"
  >
  </div>
  <div
    class="absolute w-[400px] h-[400px] bg-brand-yellow/5 rounded-full blur-[100px] bottom-[-10%] right-[-10%] z-0"
  >
  </div>

  <!-- Decorative floating balloons (CSS placeholders for festivity) -->
  <div class="absolute top-[20%] left-[10%] opacity-40 animate-pulse z-0">
    <div
      class="w-12 h-16 bg-gradient-to-tr from-brand-yellow/40 to-yellow-200/40 rounded-full shadow-lg"
    >
    </div>
    <div class="w-0.5 h-16 bg-black/10 mx-auto mt-2"></div>
  </div>

  <div
    class="absolute top-[30%] right-[15%] opacity-30 animate-bounce -z-0"
    style="animation-duration: 4s;"
  >
    <div
      class="w-16 h-20 bg-gradient-to-tr from-brand-yellow/30 to-black/5 rounded-full shadow-lg"
    >
    </div>
    <div class="w-0.5 h-20 bg-black/10 mx-auto mt-2"></div>
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-4 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center lg:items-start pt-28 lg:pt-44"
  >
    <!-- Hero Text Content -->
    <div class="flex flex-col gap-6 text-center lg:text-left">
      <div
        class="inline-flex w-max mx-auto lg:mx-0 items-center gap-2 bg-brand-yellow/10 border border-brand-yellow/30 text-brand-yellow px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide uppercase shadow-[0_0_10px_rgba(255,184,0,0.1)]"
      >
        <span class="w-2 h-2 rounded-full bg-brand-yellow animate-ping"></span>
        Edição Especial de Aniversário
      </div>

      <h1
        class="text-4xl md:text-6xl font-extrabold text-brand-dark leading-tight tracking-tight"
      >
        <span class="text-brand-yellow">2 Anos</span> da Ratoeira Ads com a maior
        oferta da <span
          class="bg-gradient-to-r from-brand-yellow-hover to-brand-yellow bg-clip-text text-transparent"
          >nossa história.</span
        >
      </h1>

      <p
        class="text-lg md:text-xl text-brand-text/80 max-w-2xl mx-auto lg:mx-0 leading-relaxed"
      >
        Não perca a chance de transformar o seu ROI. Acesso vitalício à
        ferramenta que mais de <strong class="text-brand-dark"
          >+2.000 afiliados</strong
        > usam para bloquear bots e ver o lucro real das campanhas.
      </p>

      <ul
        class="text-left mt-4 mb-6 space-y-3 mx-auto lg:mx-0 inline-block w-max"
      >
        <li class="flex items-center gap-3 text-brand-text">
          <svg
            class="w-5 h-5 text-brand-yellow flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 20 20"
            ><path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path></svg
          >
          <span class="font-medium">100% de rastreamento das suas vendas.</span>
        </li>
        <li class="flex items-center gap-3 text-brand-text">
          <svg
            class="w-5 h-5 text-brand-yellow flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 20 20"
            ><path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path></svg
          >
          <span class="font-medium"
            >Bloqueio inteligente contra cliques falsos.</span
          >
        </li>
        <li class="flex items-center gap-3 text-brand-text">
          <svg
            class="w-5 h-5 text-brand-yellow flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 20 20"
            ><path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path></svg
          >
          <span class="font-medium text-brand-yellow"
            >Desconto exclusivo e por tempo limitado.</span
          >
        </li>
      </ul>

      <div
        class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
      >
        <a
          href="#planos"
          class="inline-flex items-center justify-center gap-3 bg-brand-yellow hover:bg-brand-yellow-hover text-brand-dark font-black text-lg py-5 px-10 rounded-full text-center transition-all duration-300 shadow-[0_15px_40px_rgba(255,184,0,0.3)] hover:shadow-[0_20px_50px_rgba(255,184,0,0.5)] transform hover:-translate-y-1 active:scale-95 uppercase tracking-tight"
        >
          REVELAR OFERTA AGORA
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="3"
              d="M9 5l7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>

    <!-- Hero Visual Area (Anniversary Cake) -->
    <div
      class="relative w-full flex justify-center lg:justify-end items-center z-20 lg:mt-0"
    >
      <div class="relative group">
        <!-- Decorative glow behind the cake -->
        <div class="absolute inset-0 bg-brand-yellow/20 blur-[80px] rounded-full scale-125 opacity-50 group-hover:opacity-80 transition-opacity duration-700"></div>
        
        <!-- Floating Anniversary Cake -->
        <div class="relative animate-float transition-transform duration-700 hover:scale-105">
           <img 
            src="/assets/anniversary_cake.png" 
            alt="Bolo de Aniversário 2 Anos Ratoeira Ads" 
            class="w-full max-w-[500px] h-auto drop-shadow-[0_40px_100px_rgba(255,184,0,0.1)] mix-blend-multiply brightness-[1.03] contrast-[1.03] mask-[radial-gradient(ellipse_at_center,black_50%,transparent_90%)]"
          />
        </div>

        <!-- 2 Years Badge Floating -->
        <div class="absolute -top-4 -right-4 bg-brand-dark text-brand-yellow font-black px-6 py-4 rounded-2xl shadow-2xl transform rotate-12 animate-bounce-slow border-2 border-brand-yellow/30 flex items-center justify-center min-w-[120px]">
          <span class="text-3xl tracking-tighter">2 ANOS</span>
        </div>
      </div>
    </div>
  </div>
</section>

