---
// Hero.astro
---
<section class="relative w-full min-h-screen pt-32 pb-20 flex items-center bg-brand-dark overflow-hidden">
  
  <!-- Subtle dark gradient & overlay to create depth -->
  <div class="absolute inset-0 bg-gradient-to-tr from-[#0a0a0a] via-[#1a1a1a] to-[#2a2a2a] opacity-90 z-0"></div>
  <div class="absolute w-[500px] h-[500px] bg-brand-yellow/10 rounded-full blur-[100px] top-0 left-[-20%] z-0"></div>
  <div class="absolute w-[400px] h-[400px] bg-brand-yellow/5 rounded-full blur-[100px] bottom-[-10%] right-[-10%] z-0"></div>

  <!-- Decorative floating balloons (CSS placeholders for festivity) -->
  <div class="absolute top-[20%] left-[10%] opacity-40 animate-pulse z-0">
    <div class="w-12 h-16 bg-gradient-to-tr from-brand-yellow/40 to-yellow-200/40 rounded-full shadow-xl"></div>
    <div class="w-0.5 h-16 bg-white/20 mx-auto mt-2"></div>
  </div>
  
  <div class="absolute top-[30%] right-[15%] opacity-30 animate-bounce -z-0" style="animation-duration: 4s;">
    <div class="w-16 h-20 bg-gradient-to-tr from-brand-yellow/30 to-white/40 rounded-full shadow-xl"></div>
    <div class="w-0.5 h-20 bg-white/10 mx-auto mt-2"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    
    <!-- Hero Text Content -->
    <div class="flex flex-col gap-6 text-center lg:text-left">
      <div class="inline-flex w-max mx-auto lg:mx-0 items-center gap-2 bg-brand-yellow/10 border border-brand-yellow/30 text-brand-yellow px-4 py-1.5 rounded-full text-sm font-semibold tracking-wide uppercase shadow-[0_0_10px_rgba(255,184,0,0.1)]">
        <span class="w-2 h-2 rounded-full bg-brand-yellow animate-ping"></span>
        Edição Especial de Aniversário
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight tracking-tight">
        <span class="text-brand-yellow">2 Anos</span> da Ratoeira Ads com a maior oferta da <span class="bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">nossa história.</span>
      </h1>
      
      <p class="text-lg md:text-xl text-brand-text/80 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
        Não perca a chance de transformar o seu ROI. Acesso vitalício à ferramenta que mais de <strong class="text-white">+10.000 afiliados</strong> usam para bloquear bots e ver o lucro real das campanhas.
      </p>

      <ul class="text-left mt-4 mb-6 space-y-3 mx-auto lg:mx-0 inline-block w-max">
        <li class="flex items-center gap-3 text-brand-text">
          <svg class="w-5 h-5 text-brand-yellow flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
          <span class="font-medium">100% de rastreamento das suas vendas.</span>
        </li>
        <li class="flex items-center gap-3 text-brand-text">
          <svg class="w-5 h-5 text-brand-yellow flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
          <span class="font-medium">Bloqueio inteligente contra cliques falsos.</span>
        </li>
        <li class="flex items-center gap-3 text-brand-text">
          <svg class="w-5 h-5 text-brand-yellow flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
          <span class="font-medium text-brand-yellow">Desconto exclusivo e por tempo limitado.</span>
        </li>
      </ul>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a href="#planos" class="bg-brand-yellow hover:bg-brand-yellow-hover text-brand-dark font-extrabold text-lg py-4 px-8 rounded-lg text-center transition-all duration-300 shadow-[0_0_20px_rgba(255,184,0,0.4)] hover:shadow-[0_0_30px_rgba(255,184,0,0.6)] transform hover:-translate-y-1">
          REVELAR OFERTA AGORA
        </a>
      </div>
      
    </div>

    <!-- Hero Image Area (Festive Mockup or Cake) -->
    <div class="relative w-full h-[400px] md:h-[500px] flex justify-center items-center perspective-1000">
      
      <!-- Generated Cake Image Image -->
      <div class="relative w-full h-full max-w-sm mx-auto flex justify-center items-center z-20">
        <img src="/cake.png" alt="Dois Anos Ratoeira Ads" class="object-contain w-full h-full drop-shadow-[0_15px_35px_rgba(0,0,0,0.8)] filter opacity-95 transition-transform duration-700 hover:scale-105" style="mix-blend-mode: hard-light;" />
      </div>

    </div>
  </div>
</section>
