---

<section id="resultados" class="py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-4">
    
    <!-- Top Header & Mini Cards -->
    <div class="flex flex-col lg:flex-row items-start justify-between gap-12 mb-20">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-6xl font-black text-brand-dark uppercase tracking-tighter leading-[0.9] mb-8">
          RESULTADOS QUE <br />
          <span class="text-[#00c853] italic">APARECEM</span> NO EXTRATO.
        </h2>
        <p class="text-xl text-gray-500 leading-relaxed max-w-xl">
          Não é sobre software. É sobre o dinheiro que sobra no caixa quando você para de perder para fraude e rastreamento incompleto.
        </p>
      </div>
      
      <!-- Mini Highlights -->
      <div class="flex flex-wrap lg:flex-nowrap gap-4 w-full lg:w-auto">
        <!-- Recovery Card -->
        <div class="reveal-item bg-white p-6 rounded-2xl shadow-xl border-l-[6px] border-brand-yellow flex flex-col justify-center min-w-[220px] flex-1 lg:flex-none opacity-0 translate-y-8 transition-all duration-700 delay-100 hover:shadow-2xl hover:-translate-y-1">
          <span class="text-3xl font-black text-brand-dark" data-counter data-target="0.1" data-prefix="R$ " data-suffix="M">R$ 0,1M</span>
          <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1">INVESTIMENTO <br/> RECUPERADO DA FRAUDE</span>
        </div>
        <!-- Tracking Card -->
        <div class="reveal-item bg-brand-dark p-6 rounded-2xl shadow-xl flex flex-col justify-center min-w-[220px] flex-1 lg:flex-none opacity-0 translate-y-8 transition-all duration-700 delay-200 hover:shadow-2xl hover:-translate-y-1">
          <span class="text-3xl font-black text-[#00c853]" data-counter data-target="24" data-prefix="+" data-suffix="%">+24%</span>
          <span class="text-[10px] text-gray-300 font-bold uppercase tracking-widest mt-1">A MAIS EM CONVERSÕES <br/> RASTREADAS</span>
        </div>
      </div>
    </div>

    <!-- Main Impact Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
      <!-- CPA Card -->
      <div class="reveal-item bg-white p-10 rounded-3xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] border border-gray-100 flex flex-col items-start group opacity-0 translate-y-8 transition-all duration-700 delay-300 hover:shadow-2xl hover:-translate-y-2">
        <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform group-hover:bg-green-100">
          <svg class="w-6 h-6 text-[#00c853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>
        </div>
        <span class="text-5xl font-black text-brand-dark mb-4 tracking-tighter" data-counter data-target="32" data-prefix="-" data-suffix="%">-32%</span>
        <h4 class="text-lg font-black text-brand-dark uppercase tracking-tight mb-4 group-hover:text-green-600 transition-colors">No CPA médio dos usuários</h4>
        <p class="text-gray-500 font-medium">Sem pagar por bots, cada real na tela é de alguém que realmente converte.</p>
      </div>

      <!-- Fraud Card -->
      <div class="reveal-item bg-white p-10 rounded-3xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] border border-gray-100 flex flex-col items-start group opacity-0 translate-y-8 transition-all duration-700 delay-400 hover:shadow-2xl hover:-translate-y-2">
        <div class="w-14 h-14 bg-yellow-50 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform group-hover:bg-yellow-100">
          <svg class="w-6 h-6 text-brand-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        </div>
        <span class="text-5xl font-black text-brand-dark mb-4 tracking-tighter" data-counter data-target="76" data-suffix="%">76%</span>
        <h4 class="text-lg font-black text-brand-dark uppercase tracking-tight mb-4 group-hover:text-yellow-600 transition-colors">Das fraudes bloqueadas automaticamente</h4>
        <p class="text-gray-500 font-medium">Bloqueio 24h — enquanto você dorme, a Ratoeira protege.</p>
      </div>

      <!-- ROAS Card -->
      <div class="reveal-item bg-white p-10 rounded-3xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] border border-gray-100 flex flex-col items-start group opacity-0 translate-y-8 transition-all duration-700 delay-500 hover:shadow-2xl hover:-translate-y-2">
        <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform group-hover:bg-green-100">
          <svg class="w-6 h-6 text-[#00c853]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
        </div>
        <span class="text-5xl font-black text-brand-dark mb-4 tracking-tighter" data-counter data-target="2.7" data-suffix="x">2,7x</span>
        <h4 class="text-lg font-black text-brand-dark uppercase tracking-tight mb-4 group-hover:text-green-600 transition-colors">No ROAS médio em 30 dias</h4>
        <p class="text-gray-500 font-medium">Dados impulsionam o Google a buscar compradores reais no ROAS sugerido.</p>
      </div>
    </div>

    <!-- Mobile Screenshots Gallery -->
    <div class="relative mb-24">
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {screenshots.map((src, i) => (
          <div class="aspect-[9/18] rounded-[2rem] overflow-hidden border-2 border-gray-100 shadow-lg transform hover:-translate-y-2 transition-all duration-500">
            <img src={src} alt={`Resultado ${i+1}`} class="w-full h-full object-cover" />
          </div>
        ))}
      </div>
      <!-- Subtle Overlay to show continuity -->
      <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-white via-transparent to-transparent h-40 bottom-0 top-auto"></div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center">
      <p class="text-[10px] text-gray-300 font-bold uppercase tracking-[0.3em] mb-8">
        RESULTADOS MÉDIOS DE USUÁRIOS. CADA OPERAÇÃO É DIFERENTE — MAS PARAR DE PERDER COMEÇA POR AQUI.
      </p>
      
      <div class="flex flex-col items-center gap-4">
        <a 
          href="#planos" 
          class="bg-brand-yellow text-brand-dark px-10 py-5 rounded-full font-black uppercase text-sm tracking-widest flex items-center gap-3 shadow-xl hover:translate-y-[-4px] hover:shadow-2xl transition-all active:scale-95 group"
        >
          QUERO BLINDAR MINHA CONTA AGORA
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"></path></svg>
        </a>
        <span class="text-xs text-gray-400 font-medium">14 dias grátis — Sem compromisso — Cancele quando quiser</span>
      </div>
    </div>

  </div>
</section>

<script>
  function initCounters() {
    const counters = document.querySelectorAll('[data-counter]');
    const options = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Revelar o container do card
          entry.target.closest('.reveal-item')?.classList.remove('opacity-0', 'translate-y-8');
          entry.target.closest('.reveal-item')?.classList.add('opacity-100', 'translate-y-0');

          // Iniciar contagem
          animateCounter(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, options);

    // Observar também os cards que não têm contador mas precisam de reveal
    document.querySelectorAll('.reveal-item').forEach(item => {
      const counter = item.querySelector('[data-counter]');
      if (counter) {
        observer.observe(counter);
      } else {
        const itemObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.remove('opacity-0', 'translate-y-8');
              entry.target.classList.add('opacity-100', 'translate-y-0');
              itemObserver.unobserve(entry.target);
            }
          });
        }, options);
        itemObserver.observe(item);
      }
    });

    function animateCounter(el) {
      const target = parseFloat(el.getAttribute('data-target'));
      const prefix = el.getAttribute('data-prefix') || '';
      const suffix = el.getAttribute('data-suffix') || '';
      const duration = 2000; // 2 segundos
      const start = 0;
      const startTime = performance.now();

      function update(currentTime) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);

        // Easing: easeOutExpo
        const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
        
        let current = start + (target - start) * easeProgress;

        // Formatação decimal se necessário (ex: 0.1, 2.7)
        const isDecimal = el.getAttribute('data-target').includes('.');
        const displayValue = isDecimal ? current.toFixed(1).replace('.', ',') : Math.floor(current).toString();

        el.textContent = `${prefix}${displayValue}${suffix}`;

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = `${prefix}${el.getAttribute('data-target').replace('.', ',')}${suffix}`;
        }
      }

      requestAnimationFrame(update);
    }
  }

  // Rodar na inicialização e após trocas de página (Astro transitions)
  initCounters();
  document.addEventListener('astro:after-swap', initCounters);
</script>

<style>
  /* Custom shadow for the stats section */
  .shadow-premium {
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.1);
  }

  .reveal-item {
    will-change: transform, opacity;
  }
</style>
