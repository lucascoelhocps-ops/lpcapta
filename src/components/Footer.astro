---
// Footer.astro
---
<footer class="bg-brand-lighter border-t border-black/5 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
    
    <div class="flex flex-col items-center md:items-start gap-4">
      <img src="/logo.png" alt="Ratoeira Ads" class="h-8 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all" />
      <p class="text-brand-text/50 text-xs">Digital Strategy & High Performance Leads</p>
    </div>

    <div class="flex items-center gap-2 text-brand-yellow/80 hover:text-brand-yellow font-bold text-sm transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
      (19) 99727-8153
    </div>
    
  </div>

  <div class="max-w-7xl mx-auto px-4 mt-8 pt-6 border-t border-black/5 text-center flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-brand-text/60">
    <p>&copy; {new Date().getFullYear()} Ratoeira Ads Digital Marketing - 55.824.986/0001-06. Todos os direitos reservados.</p>
    <div class="flex items-center gap-4">
      <a href="/politica" class="hover:text-brand-text/80 transition-colors">Política de Privacidade</a>
      <a href="/termos" class="hover:text-brand-text/80 transition-colors">Termos de Uso</a>
    </div>
  </div>
</footer>
