<script>
  function initPricing() {
    const bundleBtns = document.querySelectorAll('[data-bundle-trigger]');
    const periodBtns = document.querySelectorAll('[data-period-trigger]');
    const bundleGroups = document.querySelectorAll('[data-bundle-group]');

    let currentBundle = 'combo';
    let currentPeriod = 'anual';

    function updateView() {
      // 1. Filter Bundle
      bundleGroups.forEach(group => {
        const el = group as HTMLElement;
        if (el.getAttribute('data-bundle-group') === currentBundle) {
          el.style.display = 'block';
          el.classList.remove('opacity-0', 'scale-95');
        } else {
          el.style.display = 'none';
          el.classList.add('opacity-0', 'scale-95');
        }
      });

      // 2. Filter Period within active Bundle
      const activeBundle = document.querySelector(`[data-bundle-group="${currentBundle}"]`) as HTMLElement;
      if (activeBundle) {
        const pGroups = activeBundle.querySelectorAll('[data-period-group]');
        pGroups.forEach(pg => {
          const el = pg as HTMLElement;
          if (el.getAttribute('data-period-group') === currentPeriod) {
            el.style.display = 'grid';
            el.classList.remove('opacity-0', 'scale-95');
          } else {
            el.style.display = 'none';
            el.classList.add('opacity-0', 'scale-95');
          }
        });
      }
    }

    // Bundle Listeners
    bundleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-bundle-trigger');
        if (val) currentBundle = val;
        bundleBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateView();
      });
    });

    // Period Listeners
    periodBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-period-trigger');
        if (val) currentPeriod = val;
        periodBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateView();
      });
    });

    // Run initial update
    updateView();
  }

