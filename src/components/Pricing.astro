    let vitalicioAdsPrice = vitalicioManualSchedule.ads[dateKey] || vitalicioManualSchedule.ads["2026-04-19"];
    let vitalicioComboPrice = vitalicioManualSchedule.combo[dateKey] || vitalicioManualSchedule.combo["2026-04-19"];
    let vitalicioPagesPrice = vitalicioManualSchedule.pages[dateKey] || vitalicioManualSchedule.pages["2026-04-19"];
    if (dateKey < "2026-04-13") {
      vitalicioAdsPrice = vitalicioManualSchedule.ads["2026-04-13"];
      vitalicioComboPrice = vitalicioManualSchedule.combo["2026-04-13"];
      vitalicioPagesPrice = vitalicioManualSchedule.pages["2026-04-13"];
    }

    const getBasePrice = (bundle: string, period: string, plan: string) => {
      return (pricingData[bundle as keyof typeof pricingData] as any)?.[period]?.[plan];
    };

    const getEffectivePrice = (bundle: string, period: string, plan: string, basePrice: number) => {
      if (bundle === "ads") {
        const exactPrice = (adsExactSchedule as any)?.[dateKey]?.[period]?.[plan];
        if (typeof exactPrice === 'number') return exactPrice;
      }
      if (bundle === "combo") {
        const exactPrice = (comboExactSchedule as any)?.[dateKey]?.[period]?.[plan];
        if (typeof exactPrice === 'number') return exactPrice;
      }
      if (bundle === "pages") {
        const exactPrice = (pagesExactSchedule as any)?.[dateKey]?.[period]?.[plan];
        if (typeof exactPrice === 'number') return exactPrice;
      }
      return basePrice * (1 - appliedDiscount);
    };

    const getEffectiveAdsParcelPrice = (period: string, plan: string) => {
      const promoValue = (adsParcelSchedule as any)?.[dateKey]?.[period]?.[plan];
      if (typeof promoValue === 'number') return promoValue;

      const baseValue = (adsParcelBase as any)?.[period]?.[plan];
      if (typeof baseValue === 'number') return baseValue;

      return null;
    };

    const getEffectivePagesParcelPrice = (period: string, plan: string) => {
      const promoValue = (pagesParcelSchedule as any)?.[dateKey]?.[period]?.[plan];
      if (typeof promoValue === 'number') return promoValue;

      const baseValue = (pagesParcelBase as any)?.[period]?.[plan];
      if (typeof baseValue === 'number') return baseValue;

      return null;
    };

    const getEffectiveParcelPrice = (bundle: string, period: string, plan: string) => {
      if (bundle === 'ads') {
        return getEffectiveAdsParcelPrice(period, plan);
      }

      if (bundle === 'combo') {
        if (period === 'vitalicio' && plan === 'ratazana') {
          return vitalicioComboPrice / 12;
        }

        const basePrice = getBasePrice(bundle, period, plan);
        if (basePrice === undefined) return null;

        const effectivePrice = getEffectivePrice(bundle, period, plan, basePrice);
        const installments = period === 'anual' ? 12 : period === 'semestral' ? 6 : 1;
        return effectivePrice / installments;
      }

      if (bundle === 'pages') {
        return getEffectivePagesParcelPrice(period, plan);
      }

      return null;
    };

    const getBaseParcelPrice = (bundle: string, period: string, plan: string) => {
      if (bundle === 'ads') {
        const baseValue = (adsParcelBase as any)?.[period]?.[plan];
        return typeof baseValue === 'number' ? baseValue : null;
      }

      if (bundle === 'combo') {
        if (period === 'vitalicio' && plan === 'ratazana') {
          return vitalicioManualSchedule.combo["2026-04-19"] / 12;
        }
        const basePrice = getBasePrice(bundle, period, plan);
        if (basePrice === undefined) return null;
        const installments = period === 'anual' ? 12 : period === 'semestral' ? 6 : 1;
        return basePrice / installments;
      }

      if (bundle === 'pages') {
        const baseValue = (pagesParcelBase as any)?.[period]?.[plan];
        return typeof baseValue === 'number' ? baseValue : null;
      }

      return null;
    };

    document.querySelectorAll('[data-price-parcel-calc]').forEach(el => {
      const bundleAttr = el.getAttribute('data-calc-bundle');
      const periodAttr = el.getAttribute('data-calc-period');
      const planAttr = el.getAttribute('data-calc-plan');

      if (!bundleAttr || !periodAttr || !planAttr) return;

      const parcelPrice = getEffectiveParcelPrice(bundleAttr, periodAttr, planAttr);
      if (parcelPrice === null) return;

      const baseParcelPrice = getBaseParcelPrice(bundleAttr, periodAttr, planAttr);
      const parcelPrefix = periodAttr === 'anual' ? '12x ' : periodAttr === 'semestral' ? '6x ' : '';
      const card = (el as HTMLElement).closest('.relative');
      const isDarkCard = card?.classList.contains('bg-black');
      const strikeClass = isDarkCard ? 'text-white/60' : 'text-brand-dark/40';

      if (baseParcelPrice !== null && parcelPrice < baseParcelPrice) {
        el.innerHTML = `<span class="text-sm ${strikeClass} line-through block mb-1">${parcelPrefix}R$ ${baseParcelPrice.toFixed(2).replace('.',',')}</span>${parcelPrefix}R$ ${parcelPrice.toFixed(2).replace('.',',')}`;
      } else {
        el.innerHTML = `${parcelPrefix}R$ ${parcelPrice.toFixed(2).replace('.',',')}`;
      }
    });

    document.querySelectorAll('[data-price-calc-main]').forEach(el => {
      const bundleAttr = el.getAttribute('data-calc-bundle');
      const periodAttr = el.getAttribute('data-calc-period');
      const planAttr = el.getAttribute('data-calc-plan');
      
      if (!bundleAttr || !periodAttr || !planAttr) return;

      const basePrice = getBasePrice(bundleAttr, periodAttr, planAttr);
      if (basePrice === undefined) return;

      const discountedPrice = getEffectivePrice(bundleAttr, periodAttr, planAttr, basePrice);
      const card = (el as HTMLElement).closest('.relative');
      const isDarkCard = card?.classList.contains('bg-black');
      const strikeClass = isDarkCard ? 'text-white/60' : 'text-brand-dark/35';

      if (discountedPrice < basePrice) {
        el.innerHTML = `<span class="text-sm ${strikeClass} line-through block mb-1">R$ ${basePrice.toFixed(2).replace('.',',')}</span>R$ ${discountedPrice.toFixed(2).replace('.',',')}`;
      } else {
        el.innerHTML = `R$ ${basePrice.toFixed(2).replace('.',',')}`;
      }
    });

    document.querySelectorAll('[data-price-calc]').forEach(el => {
      const bundleAttr = el.getAttribute('data-calc-bundle');
      const periodAttr = el.getAttribute('data-calc-period');
      const planAttr = el.getAttribute('data-calc-plan');
      
      if (!bundleAttr || !periodAttr || !planAttr) return;

      const basePrice = getBasePrice(bundleAttr, periodAttr, planAttr);
      if (basePrice === undefined) return;

      const discountedPrice = getEffectivePrice(bundleAttr, periodAttr, planAttr, basePrice);
      const card = (el as HTMLElement).closest('.relative');
      const isDarkCard = card?.classList.contains('bg-black');
      const strikeClass = isDarkCard ? 'text-white/55' : 'text-brand-dark/45';
      
      if (discountedPrice < basePrice) {
        el.innerHTML = `<span class="text-sm ${strikeClass} line-through block -mb-1">De R$ ${basePrice.toFixed(2).replace('.',',')}</span>R$ ${discountedPrice.toFixed(2).replace('.',',')}`;
      } else {
        el.innerHTML = `R$ ${basePrice.toFixed(2).replace('.',',')}`;
      }
    });

    // Update Vitalicio
    document.querySelectorAll('[data-price-vitalicio]').forEach(el => {
      const bundle = el.getAttribute('data-calc-bundle');
      if (!bundle) return;
      const priceMap: Record<string, number> = {
        ads: vitalicioAdsPrice,
        combo: vitalicioComboPrice,
        pages: vitalicioPagesPrice
      };
      const price = priceMap[bundle];
      if (price === undefined) return;
      
      el.innerHTML = `R$ ${price.toFixed(2).replace('.',',')}`;
    });

    document.querySelectorAll('[data-price-vitalicio-parcel]').forEach(el => {
      const bundle = el.getAttribute('data-calc-bundle');
      if (!bundle) return;
      const adsParcel = getEffectiveAdsParcelPrice('vitalicio', 'ratazana');
      const pagesParcel = getEffectivePagesParcelPrice('vitalicio', 'ratazana');
      const parcelPriceMap: Record<string, number> = {
        ads: adsParcel !== null ? adsParcel : vitalicioAdsPrice / 12,
        combo: vitalicioComboPrice / 12,
        pages: pagesParcel !== null ? pagesParcel : vitalicioPagesPrice / 12
      };
      const parcelPrice = parcelPriceMap[bundle];
      if (parcelPrice === undefined) return;
      const baseParcelPriceMap: Record<string, number> = {
        ads: adsParcelBase.vitalicio.ratazana,
        combo: vitalicioManualSchedule.combo["2026-04-19"] / 12,
        pages: pagesParcelBase.vitalicio.ratazana
      };
      const baseParcelPrice = baseParcelPriceMap[bundle];
      const card = (el as HTMLElement).closest('.relative');
      const isDarkCard = card?.classList.contains('bg-black');
      const strikeClass = isDarkCard ? 'text-white/60' : 'text-brand-dark/40';

      if (parcelPrice < baseParcelPrice) {
        el.innerHTML = `<span class="text-sm ${strikeClass} line-through block mb-1">12x R$ ${baseParcelPrice.toFixed(2).replace('.',',')}</span>12x R$ ${parcelPrice.toFixed(2).replace('.',',')}`;
      } else {
        el.innerHTML = `12x R$ ${parcelPrice.toFixed(2).replace('.',',')}`;
      }
    });

    normalizeBadgeContrast();
    removeCardDiscountCounters();
  }

  // Support for Astro Page Transitions
  document.addEventListener('astro:after-swap', () => {
    initPricing();
    updateDynamicPrices();
    initPriceAutoRefresh();
    initCheckoutPopup();
  });
</script>

<style>
  img[src="/logoraads2.png"],
  img[src="/logo_ads_pages.png"] {
    width: 3.25rem !important;
    height: 3.25rem !important;
  }
</style>
