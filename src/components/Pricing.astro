    const vitalicioManualSchedule: Record<string, Record<string, number>> = {
      ads: {
        "2026-04-13": 3497, "2026-04-14": 3597, "2026-04-15": 3697,
        "2026-04-16": 3747, "2026-04-17": 3797, "2026-04-18": 3897,
