<script>
  function initPricing() {
    const bundleBtns = document.querySelectorAll('[data-bundle-trigger]');
    const periodBtns = document.querySelectorAll('[data-period-trigger]');
    const bundleGroups = document.querySelectorAll('[data-bundle-group]');

    let currentBundle = 'combo';
    let currentPeriod = 'anual';

    function updateView() {
      // 1. Filter Bundle
      bundleGroups.forEach(group => {
        const el = group as HTMLElement;
        if (el.getAttribute('data-bundle-group') === currentBundle) {
          el.style.display = 'block';
          el.classList.remove('opacity-0', 'scale-95');
        } else {
          el.style.display = 'none';
          el.classList.add('opacity-0', 'scale-95');
        }
      });

      // 2. Filter Period within active Bundle
      const activeBundle = document.querySelector(`[data-bundle-group="${currentBundle}"]`) as HTMLElement;
      if (activeBundle) {
        const pGroups = activeBundle.querySelectorAll('[data-period-group]');
        pGroups.forEach(pg => {
          const el = pg as HTMLElement;
          if (el.getAttribute('data-period-group') === currentPeriod) {
            el.style.display = 'grid';
            el.classList.remove('opacity-0', 'scale-95');
          } else {
            el.style.display = 'none';
            el.classList.add('opacity-0', 'scale-95');
          }
        });
      }

      updateDynamicPrices();
    }

    // Bundle Listeners
    bundleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-bundle-trigger');
        if (val) currentBundle = val;
        bundleBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateView();
      });
    });

    // Period Listeners
    periodBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-period-trigger');
        if (val) currentPeriod = val;
        periodBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateView();
      });
    });

    // Run initial update
    updateView();
  }

  // Initial load
  initPricing();
  updateDynamicPrices();
  initCheckoutPopup();

  function initPriceAutoRefresh() {
    const win = window as any;

    if (win.__pricingRefreshInterval) {
      clearInterval(win.__pricingRefreshInterval);
    }

    win.__pricingRefreshInterval = window.setInterval(updateDynamicPrices, 15000);

    if (!win.__pricingVisibilityHooked) {
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
          updateDynamicPrices();
        }
      });
      window.addEventListener('focus', updateDynamicPrices);
      win.__pricingVisibilityHooked = true;
    }
  }

  initPriceAutoRefresh();

  function getPromoCheckoutCoupon() {
    const promoDateKeys = [
      "2026-04-13",
      "2026-04-14",
      "2026-04-15",
      "2026-04-16",
      "2026-04-17",
      "2026-04-18",
      "2026-04-19"
    ];
    const win = window as typeof window & { __promoCycleStartMs?: number };
    if (!win.__promoCycleStartMs) {
      win.__promoCycleStartMs = Date.now();
    }
    const slotMs = 10 * 60 * 1000;
    const elapsedMs = Math.max(0, Date.now() - win.__promoCycleStartMs);
    const slotIndex = Math.min(promoDateKeys.length - 1, Math.floor(elapsedMs / slotMs));
    const dateKey = promoDateKeys[slotIndex] || promoDateKeys[promoDateKeys.length - 1];
    const couponMap: Record<string, string> = {
      "2026-04-13": "NIVER35",
      "2026-04-14": "NIVER30",
      "2026-04-15": "NIVER29",
      "2026-04-16": "NIVER28",
      "2026-04-17": "NIVER27",
      "2026-04-18": "NIVER26",
      "2026-04-19": "NIVER25"
    };
    return couponMap[dateKey] || "NIVER25";
  }

  function extractUtmParams() {
    const url = new URL(window.location.href);
    const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
    const result: Record<string, string> = {};
    utmKeys.forEach((key) => {
      const value = url.searchParams.get(key);
      if (value) result[key] = value;
    });
    return result;
  }

  function buildQueryString(params: Array<[string, string]>) {
    return params
      .filter(([, value]) => value !== undefined && value !== null && value !== '')
      .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(value)}`)
      .join('&');
  }

  function splitPhone(rawPhone: string) {
    const digits = rawPhone.replace(/\D/g, '');
    if (digits.length < 10) {
      return { phoneLocalCode: '', phone: '' };
    }
    if (digits.length > 11) {
      const ddiLength = digits.length - 11;
      return {
        phoneLocalCode: digits.slice(0, ddiLength),
        phone: digits.slice(ddiLength)
      };
    }
    return {
      phoneLocalCode: '55',
      phone: digits
    };
  }

  function initCheckoutPopup() {
    const win = window as any;
    if (win.__checkoutPopupHooked) return;
    win.__checkoutPopupHooked = true;

    const closePopup = () => {
      const popup = document.getElementById('checkout-popup');
      if (!popup) return;
      popup.classList.add('hidden');
      popup.classList.remove('flex');
      document.body.classList.remove('overflow-hidden');
    };

    const openPopup = (checkoutTarget: string, checkoutTrigger: HTMLAnchorElement) => {
      const popup = document.getElementById('checkout-popup');
      const form = document.getElementById('checkout-popup-form') as HTMLFormElement | null;
      if (!popup || !form) return;
      const periodGroup = checkoutTrigger.closest('[data-period-group]') as HTMLElement | null;
      const bundleGroup = checkoutTrigger.closest('[data-bundle-group]') as HTMLElement | null;
      form.dataset.checkoutTarget = checkoutTarget;
      form.dataset.checkoutPeriod = periodGroup?.getAttribute('data-period-group') || '';
      form.dataset.checkoutBundle = bundleGroup?.getAttribute('data-bundle-group') || '';
      form.dataset.checkoutButtonId = checkoutTrigger.id || `${form.dataset.checkoutBundle || 'bundle'}-${form.dataset.checkoutPeriod || 'period'}-assinar`;
      popup.classList.remove('hidden');
      popup.classList.add('flex');
      document.body.classList.add('overflow-hidden');
      const firstInput = form.querySelector('input[name="name"]') as HTMLInputElement | null;
      firstInput?.focus();
    };

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      if (!target) return;

      const closeTrigger = target.closest('[data-popup-close]') as HTMLElement | null;
      if (closeTrigger) {
        closePopup();
        return;
      }

      const checkoutTrigger = target.closest('#planos [data-period-group] a[href]') as HTMLAnchorElement | null;
      if (!checkoutTrigger) return;
      event.preventDefault();
      openPopup(checkoutTrigger.getAttribute('href') || '#', checkoutTrigger);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closePopup();
      }
    });

    document.addEventListener('submit', async (event) => {
      const form = event.target as HTMLFormElement | null;
      if (!form || form.id !== 'checkout-popup-form') return;
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const checkoutTarget = form.dataset.checkoutTarget || '#';
      const name = ((form.querySelector('input[name="name"]') as HTMLInputElement | null)?.value || '').trim();
      const email = ((form.querySelector('input[name="email"]') as HTMLInputElement | null)?.value || '').trim();
      const rawPhone = ((form.querySelector('input[name="phone"]') as HTMLInputElement | null)?.value || '').trim();
      const phoneParts = splitPhone(rawPhone);
      const phoneInput = form.querySelector('input[name="phone"]') as HTMLInputElement | null;

      if (!phoneParts.phoneLocalCode || !phoneParts.phone) {
        if (phoneInput) {
          phoneInput.setCustomValidity('Informe telefone com DDI, DDD e número.');
          form.reportValidity();
          phoneInput.setCustomValidity('');
        }
        return;
      }

      const isVitalicio = (form.dataset.checkoutPeriod || '') === 'vitalicio';
      const utms = extractUtmParams();
      const queryParams: Array<[string, string]> = [
        ['name', name],
        ['phone_local_code', phoneParts.phoneLocalCode],
        ['phone', phoneParts.phone],
        ['email', email],
        ['id_forms', form.id],
        ['id_botao', form.dataset.checkoutButtonId || '']
      ];

      Object.entries(utms).forEach(([key, value]) => {
        queryParams.push([key, value]);
      });

      if (!isVitalicio) {
        queryParams.push(['coupon', getPromoCheckoutCoupon()]);
      }

      const checkoutUrl = new URL(checkoutTarget, window.location.origin);
      const queryString = buildQueryString(queryParams);
      const redirectUrl = `${checkoutUrl.origin}${checkoutUrl.pathname}?${queryString}`;

      const webhookPayload: Record<string, string> = {
        checkout_url: checkoutTarget,
        checkout_url_com_dados: redirectUrl,
        bundle: form.dataset.checkoutBundle || '',
        period: form.dataset.checkoutPeriod || '',
        id_forms: form.id,
        id_botao: form.dataset.checkoutButtonId || '',
        name,
        email,
        phone_local_code: phoneParts.phoneLocalCode,
        phone: phoneParts.phone,
        utm_source: utms.utm_source || '',
        utm_medium: utms.utm_medium || '',
        utm_campaign: utms.utm_campaign || '',
        utm_term: utms.utm_term || '',
        utm_content: utms.utm_content || ''
      };

      if (!isVitalicio) {
        webhookPayload.coupon = getPromoCheckoutCoupon();
      }

      try {
        const webhookRequest = fetch('https://n8n.srv1145908.hstgr.cloud/webhook/checkout-niver-2-anos', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(webhookPayload),
          mode: 'no-cors',
          keepalive: true
        }).catch(() => null);
        await Promise.race([webhookRequest, new Promise((resolve) => setTimeout(resolve, 800))]);
      } catch {
      }

      closePopup();
      window.location.href = redirectUrl;
    });
  }

  function removeCardDiscountCounters() {
    const allBadges = document.querySelectorAll('#planos .card-discount-badge');
    allBadges.forEach(b => b.remove());
  }

  function normalizeBadgeContrast() {
    const priceBadgeValues = document.querySelectorAll('#planos [data-price-calc], #planos [data-price-vitalicio]');

    priceBadgeValues.forEach(valueEl => {
      const hostCard = (valueEl as HTMLElement).closest('.relative');
      const badge = (valueEl as HTMLElement).closest('div');
      if (!hostCard || !badge) return;

      const isDarkCard = hostCard.classList.contains('bg-black');
      badge.classList.remove('text-white', 'text-white/70', 'text-brand-dark/60', 'text-brand-dark/70');
      badge.classList.remove('bg-brand-yellow/10', 'bg-brand-yellow/25');
      badge.classList.remove('border', 'border-brand-yellow/40');

      if (isDarkCard) {
        badge.classList.add('text-white', 'bg-brand-yellow/25', 'border', 'border-brand-yellow/40');
      } else {
        badge.classList.add('text-brand-dark/70', 'bg-brand-yellow/10');
      }
    });
  }

