---
// ProductFeatures.astro
---

<section id="como-funciona-features" class="bg-[#eef0f3] py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6 md:px-10">

    <!-- Header principal da seção -->
    <div class="text-center mb-16 md:mb-24 max-w-3xl mx-auto">
      <p class="text-[10px] md:text-xs font-bold uppercase tracking-[0.3em] text-gray-400 mb-5">
        A RATOEIRA É A ÚNICA FERRAMENTA NO MERCADO PARA GOOGLE ADS
      </p>
      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight">
        A única ferramenta brasileira que rastreia,
        <span class="text-brand-yellow"> protege</span> e dá
        <span class="text-[#16a34a]"> visão total</span>
        da sua operação no Google Ads.
      </h2>
    </div>

    <!-- Feature 1: Texto Esquerda / Imagem Direita -->
    <div class="flex flex-col lg:flex-row items-center gap-12 md:gap-16 mb-20 md:mb-28">
      <!-- Texto -->
      <div class="flex-1 order-2 lg:order-1">
        <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-gray-400 mb-4">
          RASTREAMENTO DE PRECISÃO
        </p>
        <h3 class="text-4xl md:text-5xl font-black uppercase leading-none tracking-tight text-gray-900 mb-8">
          CADA VENDA<br>
          RASTREADA. CADA<br>
          CLIQUE IDENTIFICADO.
        </h3>
        <ul class="space-y-5">
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Identifica <strong>quase 100% das conversões</strong> — inclusive as que o Google não registrou</span>
          </li>
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Mostra qual clique, campanha e criativo gerou cada venda real</span>
          </li>
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Permite usar Smart Bidding com <strong>dados limpos</strong> para escalar com segurança</span>
          </li>
        </ul>
      </div>
      <!-- Imagem -->
      <div class="flex-1 order-1 lg:order-2">
        <img
          src="https://ratoeiraadsoficial.com.br/wp-content/uploads/2026/01/tracking-de-conversoes-de-verdade.webp"
          alt="Rastreamento de conversões no celular"
          class="w-full max-w-lg mx-auto lg:ml-auto drop-shadow-xl"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Feature 2: Imagem Esquerda / Texto Direita -->
    <div class="flex flex-col lg:flex-row items-center gap-12 md:gap-16 mb-20 md:mb-28">
      <!-- Imagem -->
      <div class="flex-1">
        <img
          src="https://ratoeiraadsoficial.com.br/wp-content/uploads/2026/01/BLOQUEIO-DE-RATOS-E-BOTS.webp"
          alt="Bloqueio de bots e concorrentes"
          class="w-full max-w-lg mx-auto lg:mr-auto drop-shadow-xl"
          loading="lazy"
        />
      </div>
      <!-- Texto -->
      <div class="flex-1">
        <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-gray-400 mb-4">
          BLINDAGEM ANTI-FRAUDE
        </p>
        <h3 class="text-4xl md:text-5xl font-black uppercase leading-none tracking-tight text-gray-900 mb-8">
          BOTS E CONCORRENTES<br>
          BLOQUEADOS.<br>
          ORÇAMENTO<br>
          PRESERVADO.
        </h3>
        <ul class="space-y-5">
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Detecta bots e cliques de concorrentes antes de atingirem seu anúncio</span>
          </li>
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span><strong>Bloqueia IPs fraudulentos automaticamente</strong>, sem intervenção manual</span>
          </li>
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Orçamento 100% direcionado a tráfego humano desde o primeiro dia</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Feature 3: Texto Esquerda / Imagem Direita -->
    <div class="flex flex-col lg:flex-row items-center gap-12 md:gap-16 mb-16 md:mb-20">
      <!-- Texto -->
      <div class="flex-1 order-2 lg:order-1">
        <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-gray-400 mb-4">
          VISÃO CONSOLIDADA
        </p>
        <h3 class="text-4xl md:text-5xl font-black uppercase leading-none tracking-tight text-gray-900 mb-8">
          TODAS AS MÉTRICAS<br>
          QUE IMPORTAM.<br>
          UMA TELA SÓ.
        </h3>
        <ul class="space-y-5">
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>Chega de abrir 4 plataformas para saber se está no lucro.</span>
          </li>
          <li class="flex items-start gap-3 text-gray-700 text-base md:text-lg leading-snug">
            <svg class="w-5 h-5 text-[#22c55e] shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span><strong>Margem real, ROI, CPA e caixa</strong> em um painel feito para quem anuncia no Google.</span>
          </li>
        </ul>
      </div>
      <!-- Imagem -->
      <div class="flex-1 order-1 lg:order-2">
        <img
          src="https://ratoeiraadsoficial.com.br/wp-content/uploads/2026/01/UM-DASHBOARD-INCRIVEL.webp"
          alt="Dashboard com todas as métricas em uma tela"
          class="w-full max-w-lg mx-auto lg:ml-auto drop-shadow-xl"
          loading="lazy"
        />
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-4">
      <a
        href="#planos"
        class="inline-flex items-center justify-center gap-3 bg-brand-yellow hover:bg-brand-yellow-hover text-brand-dark font-black text-lg py-5 px-10 rounded-full transition-all duration-300 shadow-[0_8px_30px_rgba(255,184,0,0.35)] hover:shadow-[0_12px_40px_rgba(255,184,0,0.5)] transform hover:-translate-y-1 uppercase tracking-tight"
      >
        Iniciar Grátis — 14 Dias
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
      </a>
      <p class="mt-4 text-sm text-gray-400">Sem fidelidade em contrato. Cancele a qualquer momento.</p>
    </div>

  </div>
</section>
