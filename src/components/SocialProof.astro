---
// SocialProof.astro
---
<section id="plataformas" class="py-12 bg-brand-darker border-y border-white/5 relative overflow-hidden">
  
  <div class="max-w-7xl mx-auto px-4 relative z-10">
    <div class="text-center mb-10">
      <h3 class="text-xl md:text-2xl font-bold text-white mb-2">Conectado às principais plataformas</h3>
      <p class="text-brand-text/60">Integração nativa para cruzar dados e limpar seu tráfego onde você mais precisa.</p>
    </div>

    <!-- Logos Grid -->
    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12 lg:gap-16 opacity-80">
      
      <!-- Google Ads (Active) -->
      <div class="flex flex-col items-center gap-2 group transition-all duration-300 hover:opacity-100 opacity-90 scale-105">
        <div class="w-16 h-16 md:w-20 md:h-20 bg-brand-card rounded-2xl flex items-center justify-center p-4 border border-brand-yellow/30 shadow-[0_0_15px_rgba(255,184,0,0.15)]">
           <svg class="w-full h-full" viewBox="0 0 48 48"><path fill="#fbc02d" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/></svg>
        </div>
        <span class="text-sm font-semibold text-white">Google Ads</span>
        <span class="text-[10px] uppercase text-green-400 font-bold tracking-wider">Online</span>
      </div>

      <!-- Meta (Em Breve) -->
      <div class="flex flex-col items-center gap-2 group transition-all duration-300 hover:opacity-100 opacity-50 grayscale hover:grayscale-0">
        <div class="w-16 h-16 md:w-20 md:h-20 bg-brand-card rounded-2xl flex items-center justify-center p-4 border border-white/10">
           <svg class="w-full h-full text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </div>
        <span class="text-sm font-semibold text-brand-text/70 group-hover:text-white transition-colors">Meta Ads</span>
        <span class="text-[10px] uppercase text-brand-text/40 font-bold tracking-wider">Em Breve</span>
      </div>

      <!-- TikTok (Em Breve) -->
      <div class="flex flex-col items-center gap-2 group transition-all duration-300 hover:opacity-100 opacity-50 grayscale hover:grayscale-0">
        <div class="w-16 h-16 md:w-20 md:h-20 bg-brand-card rounded-2xl flex items-center justify-center p-4 border border-white/10">
           <!-- TikTok Icon SVG simplified -->
           <svg class="w-full h-full text-white" fill="currentColor" viewBox="0 0 448 512"><path d="M448,209.91a210.06,210.06,0,0,1-122.77-39.25V349.38A162.55,162.55,0,1,1,185,188.31V278.2a74.62,74.62,0,1,0,52.23,71.18V0l88,0a121.18,121.18,0,0,0,1.86,22.17h0A122.18,122.18,0,0,0,381,102.39a121.43,121.43,0,0,0,67,20.14Z"/></svg>
        </div>
        <span class="text-sm font-semibold text-brand-text/70 group-hover:text-white transition-colors">TikTok Ads</span>
        <span class="text-[10px] uppercase text-brand-text/40 font-bold tracking-wider">Em Breve</span>
      </div>

    </div>
  </div>
</section>
