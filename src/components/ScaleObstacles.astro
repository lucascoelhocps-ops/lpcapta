---
---

<section id="obstaculos" class="py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <!-- Section Header -->
    <div class="max-w-4xl mx-auto text-center mb-20">
      <div class="inline-flex items-center gap-2 bg-red-50 text-red-600 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest mb-6 border border-red-100 italic">
        <span>⚠️</span> OBSTÁCULOS DA ESCALA
      </div>
      <h2 class="text-4xl md:text-6xl font-black text-brand-dark uppercase tracking-tighter leading-[0.9]">
        POR QUE SUA ESCALA <br />
        <span class="text-[#ff0000]">ESTÁ TRAVADA?</span>
      </h2>
    </div>

    <!-- Pains Blocks -->
    <div class="space-y-32">
      
      <!-- Block 1: Hemorragia Invisível -->
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 order-2 lg:order-1">
          <span class="text-gray-400 font-black text-xs uppercase tracking-[0.2em] mb-4 block">HEMORRAGIA INVISÍVEL</span>
          <h3 class="text-3xl md:text-5xl font-black text-brand-dark uppercase tracking-tight leading-none mb-8">
            BOTS E CONCORRENTES CONSUMINDO SEU ORÇAMENTO
          </h3>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Até <span class="font-black text-brand-dark">40% do seu tráfego</span> não é humano. Cada bot que clica drena orçamento e ainda ensina o Google a buscar mais gente que <span class="font-black text-brand-dark">nunca vai comprar</span>.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              SALDO DESAPARECE SEM CONVERSÃO REAL
            </li>
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              MÉTRICAS PARECEM BOAS, MAS O CAIXA SANGRA
            </li>
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              ALGORITMO OTIMIZANDO PARA O PERFIL ERRADO
            </li>
          </ul>
        </div>
        <div class="w-full lg:w-1/2 order-1 lg:order-2 relative">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-gray-100">
            <img 
              src="https://freemium.ratoeiraadsoficial.com.br/assets/pains/dashboard_resumo.png" 
              alt="Dashboard de Bloqueio" 
              class="w-full h-auto"
            />
          </div>
          <!-- Icon Badge -->
          <div class="absolute -bottom-6 -right-6 w-16 h-16 bg-brand-dark rounded-2xl flex items-center justify-center shadow-xl border-4 border-white">
            <svg class="w-8 h-8 text-red-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12,2A10,10,0,0,0,2,12a10,10,0,0,0,10,10,10,10,0,0,0,10-10A10,10,0,0,0,12,2Zm5.5,13.5a1,1,0,0,1-1,1H7.5a1,1,0,0,1-1-1v-4a1,1,0,0,1,1-1h9a1,1,0,0,1,1,1Zm-8-3a1.5,1.5,0,1,0-1.5-1.5A1.5,1.5,0,0,0,9.5,12.5Zm5,0a1.5,1.5,0,1,0-1.5-1.5A1.5,1.5,0,0,0,14.5,12.5Z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Block 2: Ponto Cego -->
      <div class="flex flex-col lg:flex-row-reverse items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2">
          <span class="text-gray-400 font-black text-xs uppercase tracking-[0.2em] mb-4 block">PONTO CEGO NO DADO</span>
          <h3 class="text-3xl md:text-5xl font-black text-brand-dark uppercase tracking-tight leading-none mb-8">
            VOCÊ TEM PIXEL. MAS NÃO TEM CERTEZA.
          </h3>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Ter pixel instalado <span class="font-black text-brand-dark">não é ter rastreamento</span>. Se você está rastreando 60-75% das conversões, está escalando com base em <span class="font-black text-brand-dark">dados errados</span> — sem perceber.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              VENDAS REAIS QUE SOMEM DO PAINEL
            </li>
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              VOCÊ NÃO SABE QUAL CRIATIVO É REALMENTE O CAMPEÃO
            </li>
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              CPA IRREAL MASCARANDO PREJUÍZO REAL
            </li>
          </ul>
        </div>
        <div class="w-full lg:w-1/2 relative">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-gray-100">
            <img 
              src="https://freemium.ratoeiraadsoficial.com.br/assets/pains/economizometro.png" 
              alt="Economizometro" 
              class="w-full h-auto"
            />
          </div>
          <!-- Icon Badge -->
          <div class="absolute -bottom-6 -left-6 w-16 h-16 bg-brand-dark rounded-2xl flex items-center justify-center shadow-xl border-4 border-white">
            <svg class="w-8 h-8 text-brand-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
              <line x1="1" y1="1" x2="23" y2="23"></line>
            </svg>
          </div>
        </div>
      </div>

      <!-- Block 3: Risco de Operação -->
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 order-2 lg:order-1">
          <span class="text-gray-400 font-black text-xs uppercase tracking-[0.2em] mb-4 block">RISCO DE OPERAÇÃO</span>
          <h3 class="text-3xl md:text-5xl font-black text-brand-dark uppercase tracking-tight leading-none mb-8">
            UMA SUSPENSÃO ENCERRA O QUE VOCÊ CONSTRUIU
          </h3>
          <p class="text-xl text-gray-600 leading-relaxed mb-8">
            Cliques inválidos <span class="font-black text-brand-dark">não passam despercebidos</span> pelo Google. Uma suspensão não apaga só o lucro — leva junto o pixel, o histórico e <span class="font-black text-brand-dark">meses de aprendizado</span> do algoritmo.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              OPERAÇÃO PODE PARAR DO DIA PARA A NOITE
            </li>
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              HISTÓRICO E INTELIGÊNCIA DO PIXEL PERDIDOS
            </li>
            <li class="flex items-start gap-3 text-gray-500 font-bold uppercase text-sm tracking-wide">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ff0000] mt-1.5 shrink-0"></span>
              SEM RECEITA ENQUANTO TENTA RECUPERAR O ACESSO
            </li>
          </ul>
        </div>
        <div class="w-full lg:w-1/2 order-1 lg:order-2 relative">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-gray-100">
            <img 
              src="https://freemium.ratoeiraadsoficial.com.br/assets/pains/ip_bloqueado.png" 
              alt="IP Bloqueado" 
              class="w-full h-auto"
            />
          </div>
          <!-- Icon Badge -->
          <div class="absolute -bottom-6 -right-6 w-16 h-16 bg-brand-dark rounded-2xl flex items-center justify-center shadow-xl border-4 border-white">
            <svg class="w-8 h-8 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <line x1="9.17" y1="9.17" x2="14.83" y2="14.83"></line>
              <line x1="14.83" y1="9.17" x2="9.17" y2="14.83"></line>
            </svg>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
