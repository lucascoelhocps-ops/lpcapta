---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProofMarquee from '../components/SocialProofMarquee.astro';
import SocialProof from '../components/SocialProof.astro';
import Pricing from '../components/Pricing.astro';
import ProductDemo from '../components/ProductDemo.astro';
import HighConversionFeatures from '../components/HighConversionFeatures.astro';
import ResultsOnStatement from '../components/ResultsOnStatement.astro';
import ChainCarousel from '../components/ChainCarousel';
import PromoCountdown from '../components/PromoCountdown.tsx';
import FAQ from '../components/FAQ.tsx';
import Footer from '../components/Footer.astro';

const platforms = [
  { id: 'hotmart', name: 'Hotmart', details: 'INTEGRADO' },
  { id: 'kiwify', name: 'Kiwify', details: 'INTEGRADO' },
  { id: 'eduzz', name: 'Eduzz', details: 'INTEGRADO' },
  { id: 'perfectpay', name: 'PerfectPay', details: 'INTEGRADO' },
  { id: 'monetizze', name: 'Monetizze', details: 'INTEGRADO' },
  { id: 'ticto', name: 'Ticto', details: 'INTEGRADO' },
  { id: 'braip', name: 'Braip', details: 'INTEGRADO' },
  { id: 'doppus', name: 'Doppus', details: 'INTEGRADO' },
  { id: 'kirvano', name: 'Kirvano', details: 'INTEGRADO' },
  { id: 'cakto', name: 'Cakto', details: 'INTEGRADO' },
  { id: 'greenn', name: 'Greenn', details: 'INTEGRADO' },
];

// A promoção é de Aniversário e requer impacto visual!
---

<Layout title="Ratoeira Ads - 2 Anos (Edição Especial)">
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <PromoCountdown client:visible />
    <Pricing />
    <SocialProofMarquee />
    <ProductDemo />
    <HighConversionFeatures />
    <ChainCarousel client:load items={platforms} />
    <ResultsOnStatement />
    <FAQ client:visible />
  </main>
  <Footer />
</Layout>
